www.tgrbservice.ru {
	redir https://tgrbservice.ru{uri} permanent
}

tgrbservice.ru {

	# WP-parsing block
	@wp_probes path /xmlrpc.php /wp-admin/* /wp-login.php /wordpress/* /wp/* /blog/*
	respond @wp_probes 444
	
	encode gzip
	reverse_proxy app:8000

	header {
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}

	log {
		output stdout
		format console
	}
}
